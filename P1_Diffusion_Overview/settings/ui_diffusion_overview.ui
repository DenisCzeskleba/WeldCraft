                        <property name="sizePolicy">
                         <sizepolicy hsizetype="Expanding" vsizetype="Fixed">
                          <horstretch>80</horstretch>
                          <verstretch>0</verstretch>
                         </sizepolicy>
                        </property>
                        <property name="toolTip">
                         <string>Set custom dt or use largest stable dt based on alpha and dx. (Using a custom dt larger than the automatic dt will likely result in divergence and an unstable numeric solution) 2D calculations will always use the highest stable dt.</string>
