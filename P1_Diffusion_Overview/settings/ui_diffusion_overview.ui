                      <item>
                       <widget class="QLineEdit" name="lineEdit_discret_space">
                        <property name="enabled">
                         <bool>true</bool>
                        </property>
                        <property name="sizePolicy">
                         <sizepolicy hsizetype="Expanding" vsizetype="Fixed">
                          <horstretch>80</horstretch>
                          <verstretch>0</verstretch>
                         </sizepolicy>
                        </property>
                        <property name="toolTip">
                         <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;Spacial discretization. Multiple dx are allowed.&lt;/p&gt;&lt;p&gt;Format examples: &lt;/p&gt;&lt;p&gt;0.1, 0.05, 0.01&lt;/p&gt;&lt;p&gt;0.1&lt;/p&gt;&lt;p&gt;Only the first will be used for 2D animation. All others will only be used to compare numerical accuracy to analytical 2D solution.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
                        </property>
                        <property name="text">
                         <string>0.1, 0.05, 0.01</string>
                        </property>
                       </widget>
                      </item>
                      <item>
                       <widget class="QLabel" name="label_discret_space">
                        <property name="sizePolicy">
                         <sizepolicy hsizetype="Expanding" vsizetype="Fixed">
                          <horstretch>20</horstretch>
                          <verstretch>0</verstretch>
                         </sizepolicy>
                        </property>
                        <property name="toolTip">
                         <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;Spacial discretization. Multiple dx are allowed.&lt;/p&gt;&lt;p&gt;Format examples: &lt;/p&gt;&lt;p&gt;0.1, 0.05, 0.01&lt;/p&gt;&lt;p&gt;0.1&lt;/p&gt;&lt;p&gt;Only the first will be used for 2D animation. All others will only be used to compare numerical accuracy to analytical 2D solution.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
